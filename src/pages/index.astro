---
import Base from "../layouts/Base.astro";

export const prerender = true;
---

<Base
	title="Apache Superset Specialists"
	description="Get your Superset project done in days, not months. From hosting infrastructure to custom dashboards, Super Dashboards is your expert partner."
	hideHeader={true}
>
	<!-- Hero Section -->
	<section class="hero halftone-bg">
		<div class="container">
			<div class="hero-content">
				<div class="hero-eyebrow">
					<span class="dot"></span>
					Apache Superset Specialists
				</div>
				<h1>Get Your Superset Project Done in Days, Not Months.</h1>
				<p class="subheading">
					From hosting infrastructure to custom dashboards, we've done this before. Get the power of Apache Superset without it becoming your team's side project.
				</p>
				<div class="cta-group">
					<button type="button" class="btn btn-primary open-booking-modal">Book a Consult</button>
					<a href="#services" class="btn btn-secondary">Explore Services</a>
				</div>
			</div>
			<div class="hero-video">
				<video autoplay loop muted playsinline>
					<source src="/apache-superset-dashboard-demo-video-720p.mp4" type="video/mp4" />
					Your browser does not support the video tag.
				</video>
			</div>
		</div>
		<div class="shape-divider bottom wave">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<path d="M0,0V46.29c47.79,22.2,103.59,32.17,158,28,70.36-5.37,136.33-33.31,206.8-37.5C438.64,32.43,512.34,53.67,583,72.05c69.27,18,138.3,24.88,209.4,13.08,36.15-6,69.85-17.84,104.45-29.34C989.49,25,1113-14.29,1200,52.47V0Z" fill="#F8F9FA" opacity=".8"></path>
				<path d="M0,0V15.81C13,36.92,27.64,56.86,47.69,72.05,99.41,111.27,165,111,224.58,91.58c31.15-10.15,60.09-26.07,89.67-39.8,40.92-19,84.73-46,130.83-49.67,36.26-2.85,70.9,9.42,98.6,31.56,31.77,25.39,62.32,62,103.63,73,40.44,10.79,81.35-6.69,119.13-24.28s75.16-39,116.92-43.05c59.73-5.85,113.28,22.88,168.9,38.84,30.2,8.66,59,6.17,87.09-7.5,22.43-10.89,48-26.93,60.65-49.24V0Z" fill="#F8F9FA" opacity=".5"></path>
				<path d="M0,0V5.63C149.93,59,314.09,71.32,475.83,42.57c43-7.64,84.23-20.12,127.61-26.46,59-8.63,112.48,12.24,165.56,35.4C827.93,77.22,886,95.24,951.2,90c86.53-7,172.46-45.71,248.8-84.81V0Z" fill="#F8F9FA"></path>
			</svg>
		</div>
	</section>

	<!-- Services Section -->
	<section class="services" id="services">
		<div class="shape-divider top zigzag">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<path d="M0,0 L50,40 L100,0 L150,40 L200,0 L250,40 L300,0 L350,40 L400,0 L450,40 L500,0 L550,40 L600,0 L650,40 L700,0 L750,40 L800,0 L850,40 L900,0 L950,40 L1000,0 L1050,40 L1100,0 L1150,40 L1200,0 L1200,120 L0,120 Z" fill="#F8F9FA"></path>
			</svg>
		</div>
		<div class="container">
			<h2>Everything You Need for Apache Superset Success</h2>
			<div class="services-grid">
				<div class="service-card">
					<h3>Managed Hosting</h3>
					<p>We let you focus on insights, not servers.</p>
					<p>Fast, secure, reliable hosting tuned for Apache Superset with automated updates, performance monitoring, and infrastructure management.</p>
				</div>
				<div class="service-card">
					<h3>Self-Hosting Expertise</h3>
					<p>Prefer to host within your own GCP, AWS, or on-premise infrastructure?</p>
					<p>We'll handle setup, configuration, documentation, and knowledge transfer to your team.</p>
				</div>
				<div class="service-card">
					<h3>Pre-Built Data Integrations</h3>
					<p>Stop wrestling with complex data connections and custom API work.</p>
					<p>Pre-built connectors to all the software you use to run your business—plug in and start analyzing immediately.</p>
				</div>
				<div class="service-card">
					<h3>Custom Dashboard Development</h3>
					<p>Get dashboards that answer your specific business questions—not generic templates.</p>
					<p>Our team of business analysts and data engineers craft custom reporting dashboards tailored to your unique needs.</p>
				</div>
				<div class="service-card">
					<h3>Custom Dataset & API Connectivity</h3>
					<p>Need to connect proprietary systems or handle complex data transformations?</p>
					<p>We integrate custom data sources and APIs (yes, even spreadsheets or CSV exports), handling all the technical complexity while you focus on insights.</p>
				</div>
				<div class="service-card">
					<h3>Fractional Data Team</h3>
					<p>Get expert analytics support without the cost and commitment of full-time hires.</p>
					<p>On-demand specialists for building and maintaining reports—scale your capabilities exactly when you need them.</p>
				</div>
			</div>
		</div>
		<div class="shape-divider bottom tilt">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<path d="M1200 120L0 16.48 0 0 1200 0 1200 120z" fill="#FFF5F6"></path>
			</svg>
		</div>
	</section>

	<!-- Value Proposition Section -->
	<section class="value-proposition halftone-bg">
		<div class="shape-divider top tilt">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<path d="M1200 120L0 16.48 0 0 1200 0 1200 120z" fill="#F8F9FA"></path>
			</svg>
		</div>
		<div class="container">
			<h2>Why Apache Superset with Super Dashboards</h2>
			<div class="value-grid">
				<div class="value-item">
					<div class="value-icon shield"></div>
					<h3>Full Control</h3>
					<p>Build exactly what you need. No feature limitations, no artificial constraints. Your data, your rules.</p>
				</div>
				<div class="value-item">
					<div class="value-icon unlock"></div>
					<h3>Zero Vendor Lock-In</h3>
					<p>Unlike PowerBI, Tableau, or other proprietary platforms, you're never trapped. Open-source means freedom.</p>
				</div>
				<div class="value-item">
					<div class="value-icon lightning"></div>
					<h3>Open-Source Power</h3>
					<p>Leverage the flexibility and innovation of Apache Superset without the complexity of managing it yourself.</p>
				</div>
				<div class="value-item">
					<div class="value-icon money"></div>
					<h3>No Per-Seat Pricing</h3>
					<p>No per-user fees eating into your budget. Scale your team's access without scaling your costs.</p>
				</div>
				<div class="value-item">
					<div class="value-icon tools"></div>
					<h3>End-to-End Expertise</h3>
					<p>From dashboard building with technical and business insight, to advanced features like embeddable dashboards, to deep Superset customization—we've got you covered.</p>
				</div>
				<div class="value-item">
					<div class="value-icon trophy"></div>
					<h3>Exclusive Focus</h3>
					<p>Dedicated team focused solely on Apache Superset. Deep specialization, not generalist BI consulting.</p>
				</div>
			</div>
		</div>
		<div class="shape-divider bottom wave">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#ffffff"></path>
			</svg>
		</div>
	</section>

	<!-- Trust Section -->
	<section class="trust">
		<div class="container">
			<h2>125+ Superset Projects Delivered</h2>
			<p class="description">
				While other agencies dabble in dozens of tools, we've made a deliberate choice: <strong>exclusive focus on mastering one platform</strong>. This singular dedication means deeper expertise, faster implementations, and solutions that leverage Superset's full power—whether you need managed hosting, custom development, or a complete build to run in-house.
			</p>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="cta-section halftone-bg" id="contact">
		<div class="container">
			<h2>Let's Get Your Superset Project Moving</h2>
			<p>
				It's a free 30-minute call. Even if we're not the right fit, you'll leave with a clearer understanding of Superset and how it could work for your specific project.
			</p>
			<button type="button" class="btn open-booking-modal">Book a Consultation</button>
		</div>
	</section>
</Base>
